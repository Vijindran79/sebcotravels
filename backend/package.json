{
  "name": "sebco-travels-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Node/Express/MongoDB/Socket.io backend for Sebco Travels ride-hailing. No Firebase, no Supabase, no BaaS.",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "pm2:logs": "pm2 logs sebco-travels-api",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "socket.io": "^4.7.5",
    "stripe": "^16.12.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "redis": "^4.7.0"
  }
}
