# ===== Sebco Travels backend =====
# Copy to .env and fill real values. DO NOT commit .env.

NODE_ENV=production
PORT=4000
# Comma-separated list (no trailing slash). Use * only in local dev.
ALLOWED_ORIGINS=https://sebcotravels.example.com

# ----- MongoDB (self-hosted) -----
MONGO_URI=mongodb://127.0.0.1:27017/sebcotravels

# ----- JWT -----
JWT_SECRET=replace_me_with_64_random_hex_chars
JWT_EXPIRES_IN=7d

# ----- Stripe -----
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----- Mapbox (free: 100k Matrix requests / month) -----
# Sign up at https://account.mapbox.com and copy the Default Public Token
# (starts with "pk."). The same token is used by the frontend autocomplete.
MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxxxxxxxxx

# ----- Brevo (transactional email + SMS, free 300/day) -----
# Get a key: https://app.brevo.com → Settings → SMTP & API → API Keys
# → "Generate a new API key" → name it "SEBCO Travels" → copy v3 key.
# NEVER share your Brevo login or password with anyone (including AI).
# The key below is enough for the backend to send emails on your behalf.
BREVO_API_KEY=
# The "From" address customers see in their inbox. Must be a domain you
# own AND have verified in Brevo (Settings → Senders & Domains).
BREVO_FROM_NAME=SEBCO Travels
BREVO_FROM_EMAIL=bookings@sebcotravels.co.uk
# Where the operator notifications go (every new pre-booking).
BREVO_OPERATOR_EMAIL=caniseb1@gmail.com
# SMS notifications (Brevo supports SMS in most EU countries, free tier
# includes 0 SMS — keep disabled until you upgrade).
BREVO_SMS_ENABLED=false
BREVO_OPERATOR_PHONE=+447411113636

# ----- Pricing (server-side authoritative formula) -----
# Total = FARE_BASE + (miles * FARE_PER_MILE) + sum(addons)
FARE_BASE=4.00
FARE_PER_MILE=2.20
FARE_CURRENCY=gbp
# Per-seat surcharge in major currency units (e.g. GBP).
FARE_ADDON_INFANT_SEAT=2.00
FARE_ADDON_TODDLER_SEAT=2.00
FARE_ADDON_BOOSTER_SEAT=2.00
FARE_ADDON_HEAVY_LUGGAGE=1.00

# ----- Dispatch engine -----
# How long a single driver has to accept before we move on.
DISPATCH_TIMEOUT_MS=30000
# How far we look for available drivers (meters).
DISPATCH_SEARCH_RADIUS_METERS=15000
# Hard cap on the number of drivers we will offer the job to before failing.
DISPATCH_MAX_ATTEMPTS=10
# How often the driver client may push a GPS frame to Mongo (ms). Relay to
# passenger is real-time regardless; this only throttles DB writes.
DRIVER_LOCATION_PERSIST_MS=3000

# ----- Optional: Redis (REQUIRED if you want PM2 cluster mode for sockets) -----
# Leave blank for single-process operation. When set, Socket.io will use the
# Redis adapter so multiple PM2 workers share rooms / events.
# REDIS_URL=redis://127.0.0.1:6379

# ----- Logging -----
LOG_LEVEL=info
